# Database
DATABASE_URL="postgresql://postgres:<password>@localhost:5432/resume-builder"
DIRECT_URL="postgresql://postgres:<password>@localhost:5432/resume-builder"

# Auth
AUTH_JWT_SECRET="replace-with-a-long-random-secret-at-least-32-chars"

# OpenAI Configuration
# Option 1 (Paid): Use OpenAI directly
OPENAI_API_KEY="your_openai_api_key"
OPENAI_MODEL="gpt-4o-mini"
# Option 2 (Free): Use Groq (blazing fast Llama3)
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_API_KEY=gsk_your_groq_key_here
# OPENAI_MODEL=llama-3.3-70b-versatile

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID=""

# App
NEXT_PUBLIC_APP_URL="https://ai-resume-builder-two-indol.vercel.app/"

# Email (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_SECURE="false"
EMAIL_FROM="your-email@example.com"
EMAIL_FROM_NAME="AI Resume Builder"

# Upstash Redis (For AI Rate Limiting)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
